APP_NAME="RR Monitor API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://rreapi.asquareai.com

# React admin (CORS)
FRONTEND_URL=https://rre.asquareai.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rr_monitor
DB_USERNAME=rr_monitor
DB_PASSWORD=CHANGE_ME

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

MAIL_MAILER=log
